# ============================================================
# Softlink Options Chatbot — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

PORT=3001
NODE_ENV=development

# Anthropic Claude AI (required for AI-powered responses)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Twilio WhatsApp (optional — for WhatsApp channel)
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Email notifications (optional — for lead capture / support tickets)
# Use Gmail with an App Password (not your regular password)
# Guide: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here
NOTIFY_EMAIL=info@softlinkoptions.com

# Company details (used in responses — change if needed)
COMPANY_NAME=Softlink Options Limited
COMPANY_PHONE=+254723498783
COMPANY_EMAIL=info@softlinkoptions.com
COMPANY_WEBSITE=https://softlinkoptions.co.ke
